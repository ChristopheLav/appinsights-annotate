{
  "name": "appinsights-annotate",
  "version": "2.1.1",
  "description": "A Github Action that creates deployment annotations in Application Insights",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.action.json && node esbuild.config.mjs && node lib/misc/generate-docs.js",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "lint": "eslint src/**/*.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "licensed-install": "gem install licensed -v 5.1.0 --no-document",
    "licensed-check": "licensed status",
    "licensed-generate": "licensed cache"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChristopheLav/appinsights-annotate.git"
  },
  "keywords": [
    "actions",
    "node",
    "application-insights"
  ],
  "author": "Christophe Lavalle",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ChristopheLav/appinsights-annotate/issues"
  },
  "homepage": "https://github.com/ChristopheLav/appinsights-annotate#readme",
  "dependencies": {
    "@actions/core": "3.0.1",
    "azure-actions-appservice-rest": "1.3.38",
    "azure-actions-webclient": "1.1.1",
    "uuid": "14.0.1"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@types/node": "26.0.1",
    "esbuild": "0.28.1",
    "eslint": "9.39.2",
    "eslint-plugin-github": "6.0.0",
    "js-yaml": "5.2.0",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1"
  }
}
