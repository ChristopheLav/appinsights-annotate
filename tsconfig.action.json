{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": [
      "es2022"
    ],
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/main.ts",
    "src/utilities/**/*.ts"
  ],
  "exclude": [
    "__test__",
    "lib",
    "node_modules",
    "src/misc/**"
  ]
}